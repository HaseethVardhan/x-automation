generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ManagedAccountStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
  ARCHIVED
}

enum AccountConnectionMode {
  API_ONLY
  BROWSER_ONLY
  HYBRID
}

enum CredentialType {
  X_API_TOKEN
  X_API_REFRESH_TOKEN
  BROWSER_SESSION
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
  INVALID
}

enum CompetitorSource {
  MANUAL
  SUGGESTED_ACCEPTED
}

enum CompetitorStatus {
  ACTIVE
  REJECTED
  ARCHIVED
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum RunStatus {
  QUEUED
  RUNNING
  PARTIAL
  FAILED
  COMPLETED
  REVIEWED
  CANCELED
}

enum RunPriority {
  LOW
  NORMAL
  HIGH
}

enum RunStage {
  PREPARE
  COLLECT_CREATOR_DATA
  ANALYZE_CREATOR
  SUGGEST_COMPETITORS
  COLLECT_COMPETITOR_DATA
  ANALYZE_COMPETITORS
  COLLECT_TRENDS
  SCORE_TOPICS
  GENERATE_DRAFTS
  VALIDATE_DRAFTS
  FINALIZE_RUN
}

enum StageStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  SKIPPED
}

enum SourceType {
  CREATOR_POSTS
  COMPETITOR_POSTS
  X_TRENDS
  EXTERNAL_NEWS
  EXTERNAL_WEB
}

enum TopicCandidateStatus {
  ACTIVE
  DROPPED
  SELECTED
}

enum DraftVariantStatus {
  GENERATED
  FLAGGED
  APPROVED
  REJECTED
  EDITED
}

enum ReviewDecisionType {
  APPROVED
  REJECTED
  NEEDS_RERUN
}

enum AuditEventType {
  LOGIN
  LOGOUT
  CREDENTIAL_CREATED
  CREDENTIAL_REVOKED
  MANAGED_ACCOUNT_CREATED
  MANAGED_ACCOUNT_UPDATED
  COMPETITOR_ADDED
  SUGGESTION_ACCEPTED
  RUN_CREATED
  RUN_STARTED
  RUN_STAGE_COMPLETED
  RUN_FAILED
  DRAFT_GENERATED
  DRAFT_APPROVED
  DRAFT_REJECTED
}

model AdminUser {
  id                        String                    @id @default(uuid())
  email                     String                    @unique
  passwordHash              String
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  managedAccounts           ManagedAccount[]
  managedAccountCredentials ManagedAccountCredential[]
  createdCompetitors        Competitor[]
  requestedResearchRuns     ResearchRun[]
  reviewDecisions           ReviewDecision[]
  auditEvents               AuditEvent[]
}

model ManagedAccount {
  id                   String                   @id @default(uuid())
  xHandle              String                   @unique
  displayName          String?
  category             String
  status               ManagedAccountStatus     @default(ACTIVE)
  connectionMode       AccountConnectionMode
  goalsSummary         String?
  notes                String?
  createdByAdminUserId String
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  archivedAt           DateTime?
  createdByAdminUser   AdminUser                @relation(fields: [createdByAdminUserId], references: [id])
  preferenceProfile    AccountPreference?
  credentials          ManagedAccountCredential[]
  competitors          Competitor[]
  competitorSuggestions CompetitorSuggestion[]
  researchRuns         ResearchRun[]
  auditEvents          AuditEvent[]

  @@index([status])
  @@index([category])
}

model ResearchRun {
  id                     String                 @id @default(uuid())
  managedAccountId       String
  requestedByAdminUserId String
  status                 RunStatus
  priority               RunPriority            @default(NORMAL)
  currentStage           RunStage?
  progressPercent        Int                    @default(0)
  inputSnapshot          Json
  summary                Json?
  warningCount           Int                    @default(0)
  errorCount             Int                    @default(0)
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  managedAccount         ManagedAccount         @relation(fields: [managedAccountId], references: [id])
  requestedByAdminUser   AdminUser              @relation(fields: [requestedByAdminUserId], references: [id])
  stages                 ResearchRunStage[]
  sourceSnapshots        SourceSnapshot[]
  creatorProfileArtifact CreatorProfileArtifact?
  competitorInsightArtifact CompetitorInsightArtifact?
  topicCandidates        TopicCandidate[]
  draftVariants          DraftVariant[]
  auditEvents            AuditEvent[]
  generatedCompetitorSuggestions CompetitorSuggestion[]

  @@index([managedAccountId, createdAt(sort: Desc)])
  @@index([status])
  @@index([currentStage])
}

model ResearchRunStage {
  id              String       @id @default(uuid())
  researchRunId   String
  stage           RunStage
  attemptNumber   Int          @default(1)
  status          StageStatus
  progressPercent Int          @default(0)
  inputRef        Json?
  outputRef       Json?
  errorCode       String?
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  researchRun     ResearchRun  @relation(fields: [researchRunId], references: [id])

  @@unique([researchRunId, stage, attemptNumber])
  @@index([researchRunId, stage])
  @@index([status])
}

model SourceSnapshot {
  id                String      @id @default(uuid())
  researchRunId     String
  sourceType        SourceType
  sourceKey         String
  fetchedAt         DateTime    @default(now())
  itemCount         Int         @default(0)
  rawPayload        Json
  normalizedPayload Json?
  retentionUntil    DateTime?
  createdAt         DateTime    @default(now())
  researchRun       ResearchRun @relation(fields: [researchRunId], references: [id])

  @@index([researchRunId, sourceType])
  @@index([sourceKey])
}

model CreatorProfileArtifact {
  id                        String      @id @default(uuid())
  researchRunId             String      @unique
  accountSnapshotWindowDays Int
  analyzedPostCount         Int
  styleProfile              Json
  topicProfile              Json
  engagementProfile         Json?
  exclusionsProfile         Json?
  createdAt                 DateTime    @default(now())
  researchRun               ResearchRun @relation(fields: [researchRunId], references: [id])
}

model CompetitorInsightArtifact {
  id                    String      @id @default(uuid())
  researchRunId         String      @unique
  competitorCount       Int
  postingPatternSummary Json
  topicPatternSummary   Json
  hookPatternSummary    Json
  gapOpportunities      Json?
  createdAt             DateTime    @default(now())
  researchRun           ResearchRun @relation(fields: [researchRunId], references: [id])
}

model TopicCandidate {
  id                 String               @id @default(uuid())
  researchRunId      String
  topicKey           String
  title              String
  description        String?
  sourceMix          Json
  creatorFitScore    Decimal              @db.Decimal(3, 2)
  trendMomentumScore Decimal              @db.Decimal(3, 2)
  noveltyScore       Decimal              @db.Decimal(3, 2)
  audienceFitScore   Decimal              @db.Decimal(3, 2)
  policyRiskScore    Decimal              @db.Decimal(3, 2)
  overallScore       Decimal              @db.Decimal(3, 2)
  rationale          Json
  status             TopicCandidateStatus @default(ACTIVE)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  researchRun        ResearchRun          @relation(fields: [researchRunId], references: [id])
  draftVariants      DraftVariant[]

  @@unique([researchRunId, topicKey])
  @@index([researchRunId, overallScore(sort: Desc)])
  @@index([status])
}

model DraftVariant {
  id                      String             @id @default(uuid())
  researchRunId           String
  topicCandidateId        String
  variantNumber           Int
  content                 String
  generationPromptVersion String
  modelName               String
  styleFitScore           Decimal?           @db.Decimal(3, 2)
  noveltyScore            Decimal?           @db.Decimal(3, 2)
  duplicationRiskScore    Decimal?           @db.Decimal(3, 2)
  policyRiskScore         Decimal?           @db.Decimal(3, 2)
  evidenceSummary         Json
  validationSummary       Json?
  status                  DraftVariantStatus @default(GENERATED)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  researchRun             ResearchRun        @relation(fields: [researchRunId], references: [id])
  topicCandidate          TopicCandidate     @relation(fields: [topicCandidateId], references: [id])
  reviewDecision          ReviewDecision?

  @@unique([researchRunId, topicCandidateId, variantNumber])
  @@index([researchRunId])
  @@index([status])
}

model ReviewDecision {
  id                   String             @id @default(uuid())
  draftVariantId       String             @unique
  decidedByAdminUserId String
  decision             ReviewDecisionType
  editedContent        String?
  editDistance         Int?
  notes                String?
  createdAt            DateTime           @default(now())
  draftVariant         DraftVariant       @relation(fields: [draftVariantId], references: [id])
  decidedByAdminUser   AdminUser          @relation(fields: [decidedByAdminUserId], references: [id])

  @@index([decision])
}

model AuditEvent {
  id               String         @id @default(uuid())
  actorAdminUserId String?
  managedAccountId String?
  researchRunId    String?
  eventType        AuditEventType
  entityType       String
  entityId         String
  metadata         Json?
  createdAt        DateTime       @default(now())
  actorAdminUser   AdminUser?     @relation(fields: [actorAdminUserId], references: [id])
  managedAccount   ManagedAccount? @relation(fields: [managedAccountId], references: [id])
  researchRun      ResearchRun?   @relation(fields: [researchRunId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([eventType])
  @@index([actorAdminUserId])
  @@index([managedAccountId])
  @@index([researchRunId])
}

model Competitor {
  id                       String               @id @default(uuid())
  managedAccountId         String
  xHandle                  String
  displayName              String?
  source                   CompetitorSource
  status                   CompetitorStatus     @default(ACTIVE)
  acceptedFromSuggestionId String?              @unique
  createdByAdminUserId     String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  managedAccount           ManagedAccount       @relation(fields: [managedAccountId], references: [id])
  acceptedFromSuggestion   CompetitorSuggestion? @relation("AcceptedCompetitorFromSuggestion", fields: [acceptedFromSuggestionId], references: [id])
  createdByAdminUser       AdminUser?           @relation(fields: [createdByAdminUserId], references: [id])

  @@unique([managedAccountId, xHandle])
  @@index([xHandle])
  @@index([status])
}

model CompetitorSuggestion {
  id                 String               @id @default(uuid())
  managedAccountId   String
  xHandle            String
  displayName        String?
  suggestionReason   Json
  confidenceScore    Decimal              @db.Decimal(3, 2)
  status             SuggestionStatus     @default(PENDING)
  generatedByRunId   String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  decidedAt          DateTime?
  managedAccount     ManagedAccount       @relation(fields: [managedAccountId], references: [id])
  generatedByRun     ResearchRun?         @relation(fields: [generatedByRunId], references: [id])
  acceptedCompetitor Competitor?          @relation("AcceptedCompetitorFromSuggestion")

  @@unique([managedAccountId, xHandle, status])
  @@index([xHandle])
  @@index([status])
  @@index([generatedByRunId])
}

model AccountPreference {
  id                           String         @id @default(uuid())
  managedAccountId             String         @unique
  objective                    String?
  toneGuidance                 Json?
  bannedThemes                 Json?
  bannedClaims                 Json?
  bannedFormats                Json?
  preferredFormats             Json?
  competitorSuggestionEnabled  Boolean        @default(true)
  externalTrendEnabled         Boolean        @default(true)
  noveltyLookbackDays          Int            @default(120)
  maxDraftVariants             Int            @default(3)
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  managedAccount               ManagedAccount @relation(fields: [managedAccountId], references: [id])
}

model ManagedAccountCredential {
  id                   String           @id @default(uuid())
  managedAccountId     String
  credentialType       CredentialType
  encryptedPayload     String
  keyVersion           String
  status               CredentialStatus @default(ACTIVE)
  lastValidatedAt      DateTime?
  expiresAt            DateTime?
  createdByAdminUserId String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  revokedAt            DateTime?
  managedAccount       ManagedAccount   @relation(fields: [managedAccountId], references: [id])
  createdByAdminUser   AdminUser        @relation(fields: [createdByAdminUserId], references: [id])

  @@index([managedAccountId, credentialType])
  @@index([status])
}

model Creator {
  id        String   @id @default(uuid())
  username  String   @unique
  createdAt DateTime @default(now())
}

model Trend {
  id        String   @id @default(uuid())
  keyword   String
  volume    Int?
  fetchedAt DateTime @default(now())
}

model DraftPost {
  id        String   @id @default(uuid())
  content   String
  status    String   @default("draft")
  createdAt DateTime @default(now())
}
